---
import { siteConfig } from "@/site-config";
const cfg = siteConfig.slideInCard;
if (!cfg?.enabled) return;
const side = cfg.side ?? "right";
---

<div
  id="slide-card"
  class={`slide-card slide-card--${side}`}
  aria-hidden="true"
  role="complementary"
  data-delay={String(cfg.delay ?? 7000)}
>
  <button class="slide-card__close" id="slide-card-close" aria-label="Dismiss">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <path d="M18 6 6 18M6 6l12 12"/>
    </svg>
  </button>

  <p class="slide-card__message">{cfg.message}</p>

  <a
    href={cfg.cta.url}
    target="_blank"
    rel="noopener noreferrer"
    class="slide-card__cta"
  >
    {cfg.cta.label} →
  </a>
</div>

<style>
  .slide-card {
    position: fixed;
    bottom: 5.5rem; /* clear the FAB */
    z-index: 8000;
    width: 17rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 1rem;
    padding: 1rem 1.1rem 1rem 1.1rem;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.18), 0 2px 8px rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    transition: transform 0.45s cubic-bezier(.34,1.3,.64,1), opacity 0.35s ease;
    /* hidden off-screen by default */
    opacity: 0;
    pointer-events: none;
  }

  .slide-card--right {
    right: 1.25rem;
    transform: translateX(calc(100% + 2rem));
  }

  .slide-card--left {
    left: 1.25rem;
    transform: translateX(calc(-100% - 2rem));
  }

  .slide-card--visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(0);
  }

  .slide-card--hiding {
    opacity: 0;
    pointer-events: none;
    transform: translateY(1.5rem);
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .slide-card__close {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: var(--bg-card-hover);
    border: 1px solid var(--border);
    color: var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s;
    flex-shrink: 0;
  }

  @media (hover: hover) and (pointer: fine) {
    .slide-card__close:hover { background: var(--border); }
  }

  .slide-card__message {
    font-size: 0.875rem;
    color: var(--text);
    line-height: 1.55;
    margin: 0;
    padding-right: 1.25rem; /* avoid overlap with close btn */
  }

  .slide-card__cta {
    display: inline-flex;
    align-items: center;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: opacity 0.15s;
  }

  @media (hover: hover) and (pointer: fine) {
    .slide-card__cta:hover { opacity: 0.75; }
  }

  /* On mobile push above bottom nav if needed */
  @media (max-width: 480px) {
    .slide-card {
      width: calc(100vw - 2rem);
      bottom: 1rem;
    }
    .slide-card--right { right: 1rem; }
    .slide-card--left  { left: 1rem; }
  }
</style>

<script>
  const DISMISSED_KEY = "zb-slide-dismissed";
  const card = document.getElementById("slide-card") as HTMLElement | null;

  if (card && !sessionStorage.getItem(DISMISSED_KEY)) {
    const delay = parseInt(card.dataset.delay || "7000", 10);

    function dismiss() {
      if (!card) return;
      sessionStorage.setItem(DISMISSED_KEY, "1");
      card.classList.remove("slide-card--visible");
      card.classList.add("slide-card--hiding");
      card.setAttribute("aria-hidden", "true");
    }

    setTimeout(() => {
      card.classList.add("slide-card--visible");
      card.setAttribute("aria-hidden", "false");
    }, delay);

    document.getElementById("slide-card-close")?.addEventListener("click", dismiss);
  }
</script>
