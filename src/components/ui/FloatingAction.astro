---
import { Icon } from "astro-icon/components";

export interface Props {
  label: string;
  icon?: string;
  href: string;
}

const { label, icon = "lucide:send", href } = Astro.props;
---

<a href={href} class="fab" aria-label={label}>
  <Icon name={icon} width="20" height="20" />
  <span class="fab__label">{label}</span>
</a>

<style>
  .fab {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--accent);
    color: var(--accent-fg);
    border-radius: 999px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2), var(--accent-glow);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.875rem;
    z-index: 100;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
  }

  .fab:hover {
    transform: scale(1.05) translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3), var(--accent-glow);
  }

  .fab:active {
    transform: scale(0.95);
  }

  .fab__label {
    display: none;
  }

  @media (min-width: 640px) {
    .fab__label {
      display: inline;
    }
  }

  /* Entrance animation */
  .fab {
    animation: fabAppear 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    animation-delay: 1s;
  }

  @keyframes fabAppear {
    from {
      opacity: 0;
      transform: scale(0) translateY(20px);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }
</style>
