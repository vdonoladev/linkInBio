---
import { siteConfig } from "@/site-config";
import { Icon } from "astro-icon/components";

const { theme } = siteConfig;
if (!theme.showThemeSwitcher) return;
---

<div class="fts" id="fts" aria-label="Theme controls" role="toolbar">
  <!-- Trigger pill -->
  <button
    class="fts__trigger"
    id="fts-trigger"
    aria-expanded="false"
    aria-label="Open theme switcher"
  >
    <Icon
      name="lucide:palette"
      width="16"
      height="16"
      class="fts__trigger-icon"
    />
    <span class="fts__trigger-label">Temas</span>
  </button>

  <!-- Panel -->
  <div class="fts__panel" id="fts-panel" aria-hidden="true">
    <!-- Section: color mode -->
    <div class="fts__section">
      <span class="fts__section-label">Appearance</span>
      <div class="fts__row">
        <button
          class="fts__mode-btn fts__mode-btn--light"
          data-mode="light"
          aria-label="Light mode"
          title="Light mode"
        >
          <Icon name="lucide:sun" width="14" height="14" />
          <span>Light</span>
        </button>
        <button
          class="fts__mode-btn fts__mode-btn--dark"
          data-mode="dark"
          aria-label="Dark mode"
          title="Dark mode"
        >
          <Icon name="lucide:moon" width="14" height="14" />
          <span>Dark</span>
        </button>
        <button
          class="fts__mode-btn fts__mode-btn--system"
          data-mode="system"
          aria-label="System preference"
          title="System preference"
        >
          <Icon name="lucide:monitor" width="14" height="14" />
          <span>Auto</span>
        </button>
      </div>
    </div>

    <div class="fts__divider"></div>

    <!-- Section: theme preset -->
    <div class="fts__section">
      <span class="fts__section-label">Style</span>
      <div class="fts__themes">
        <button
          class="fts__theme-btn"
          data-preset="minimal"
          title="Minimal — clean, editorial"
        >
          <span class="fts__theme-swatch fts__theme-swatch--minimal"></span>
          <span class="fts__theme-name">Minimal</span>
        </button>
        <button
          class="fts__theme-btn"
          data-preset="modern"
          title="Modern — glassmorphism, vivid"
        >
          <span class="fts__theme-swatch fts__theme-swatch--modern"></span>
          <span class="fts__theme-name">Modern</span>
        </button>
        <button
          class="fts__theme-btn"
          data-preset="neobrutalist"
          title="Neobrutalist — bold, raw"
        >
          <span class="fts__theme-swatch fts__theme-swatch--neobrutalist"
          ></span>
          <span class="fts__theme-name">Neo</span>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const THEME_KEY = "zutrabio-theme";
  const COLOR_KEY = "zutrabio-color-mode";
  const html = document.documentElement;

  const trigger = document.getElementById("fts-trigger");
  const panel = document.getElementById("fts-panel");
  const fts = document.getElementById("fts");

  // ── Toggle panel ────────────────────────────────────────────
  function openPanel() {
    panel?.removeAttribute("aria-hidden");
    panel?.classList.add("fts__panel--open");
    trigger?.setAttribute("aria-expanded", "true");
  }
  function closePanel() {
    panel?.setAttribute("aria-hidden", "true");
    panel?.classList.remove("fts__panel--open");
    trigger?.setAttribute("aria-expanded", "false");
  }

  trigger?.addEventListener("click", (e) => {
    e.stopPropagation();
    const isOpen = panel?.classList.contains("fts__panel--open");
    isOpen ? closePanel() : openPanel();
  });

  document.addEventListener("click", (e) => {
    if (!fts?.contains(e.target as Node)) closePanel();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closePanel();
  });

  // ── Color mode ───────────────────────────────────────────────
  function applyColorMode(mode: string) {
    const prefersDark = window.matchMedia(
      "(prefers-color-scheme: dark)",
    ).matches;
    const isDark = mode === "dark" || (mode === "system" && prefersDark);
    html.classList.toggle("dark", isDark);
    html.setAttribute("data-color-mode", isDark ? "dark" : "light");
    localStorage.setItem(COLOR_KEY, mode);
    updateModeButtons(mode);
  }

  function updateModeButtons(mode: string) {
    document.querySelectorAll(".fts__mode-btn").forEach((btn) => {
      btn.setAttribute(
        "aria-pressed",
        String(btn.getAttribute("data-mode") === mode),
      );
    });
  }

  document.querySelectorAll(".fts__mode-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const mode = btn.getAttribute("data-mode") || "system";
      applyColorMode(mode);
    });
  });

  // ── Theme preset ─────────────────────────────────────────────
  function applyTheme(preset: string) {
    html.setAttribute("data-theme", preset);
    localStorage.setItem(THEME_KEY, preset);
    updateThemeButtons(preset);
    // Apply custom accent color if configured
    (window as any).__zutrabioApplyAccent?.(preset);
  }

  function updateThemeButtons(preset: string) {
    document.querySelectorAll(".fts__theme-btn").forEach((btn) => {
      btn.setAttribute(
        "aria-pressed",
        String(btn.getAttribute("data-preset") === preset),
      );
    });
  }

  document.querySelectorAll(".fts__theme-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const preset = btn.getAttribute("data-preset");
      if (preset) applyTheme(preset);
    });
  });

  // ── Init ────────────────────────────────────────────────────
  const currentTheme = html.getAttribute("data-theme") || "minimal";
  const currentMode = localStorage.getItem(COLOR_KEY) || "system";
  updateThemeButtons(currentTheme);
  updateModeButtons(currentMode);
</script>

<style>
  /* ── Container ── */
  .fts {
    position: fixed;
    z-index: 150;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;

    /* Mobile: top-right, icon-only */
    top: 2.625rem;
    right: 0.625rem;
    bottom: auto;
    left: auto;
    align-items: flex-end;
  }

  /* Desktop: bottom-left, pill with label */
  @media (min-width: 640px) {
    .fts {
      top: auto;
      right: auto;
      bottom: 1.5rem;
      left: 1.5rem;
      align-items: flex-start;
    }
  }

  /* ── Trigger pill ── */
  .fts__trigger {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-muted);
    font-size: 0.8125rem;
    font-weight: 600;
    box-shadow:
      var(--shadow),
      0 2px 12px rgba(0, 0, 0, 0.08);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    transition:
      border-color var(--transition),
      color var(--transition),
      box-shadow var(--transition);
    cursor: pointer;

    /* Mobile: icon-only square */
    padding: 0.5rem;
  }

  @media (min-width: 640px) {
    .fts__trigger {
      padding: 0.5rem 0.875rem;
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .fts__trigger:hover {
      border-color: var(--border-hover);
      color: var(--text);
      box-shadow: var(--shadow-hover);
    }
  }

  .fts__trigger[aria-expanded="true"] {
    border-color: var(--accent);
    color: var(--accent);
  }

  .fts__trigger-icon {
    flex-shrink: 0;
  }

  /* Hide label on mobile */
  .fts__trigger-label {
    display: none;
  }

  @media (min-width: 640px) {
    .fts__trigger-label {
      display: inline;
    }
  }

  /* ── Panel ── */
  .fts__panel {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 1rem;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.14),
      0 2px 8px rgba(0, 0, 0, 0.08);
    -webkit-backdrop-filter: blur(16px);
    backdrop-filter: blur(16px);
    min-width: 190px;

    /* Mobile: opens below trigger (top-right) */
    order: 1;

    /* hidden state */
    opacity: 0;
    transform: translateY(-6px) scale(0.97);
    pointer-events: none;
    transition:
      opacity 0.2s ease,
      transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1);
    transform-origin: top right;
  }

  /* Desktop: opens above trigger (bottom-left) */
  @media (min-width: 640px) {
    .fts__panel {
      order: -1;
      transform: translateY(8px) scale(0.97);
      transform-origin: bottom left;
    }
  }

  .fts__panel--open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  /* ── Section ── */
  .fts__section-label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  /* ── Mode buttons ── */
  .fts__row {
    display: flex;
    gap: 0.375rem;
  }

  .fts__mode-btn {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 0.375rem;
    border: 1px solid var(--border);
    border-radius: 0.625rem;
    color: var(--text-muted);
    font-size: 0.6875rem;
    font-weight: 600;
    background: transparent;
    transition:
      border-color var(--transition),
      color var(--transition),
      background var(--transition);
    cursor: pointer;
  }

  .fts__mode-btn[aria-pressed="true"] {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(108, 71, 255, 0.07);
  }

  @media (hover: hover) and (pointer: fine) {
    .fts__mode-btn:hover {
      border-color: var(--border-hover);
      color: var(--text);
    }
    .fts__mode-btn[aria-pressed="true"]:hover {
      border-color: var(--accent);
      color: var(--accent);
    }
  }

  /* ── Divider ── */
  .fts__divider {
    height: 1px;
    background: var(--border);
    margin: -0.125rem 0;
  }

  /* ── Theme buttons ── */
  .fts__themes {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .fts__theme-btn {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    width: 100%;
    padding: 0.5rem 0.625rem;
    border: 1px solid transparent;
    border-radius: 0.625rem;
    background: transparent;
    color: var(--text-muted);
    font-size: 0.8125rem;
    font-weight: 500;
    text-align: left;
    cursor: pointer;
    transition:
      border-color var(--transition),
      color var(--transition),
      background var(--transition);
  }

  .fts__theme-btn[aria-pressed="true"] {
    border-color: var(--accent);
    color: var(--text);
    background: rgba(108, 71, 255, 0.06);
  }

  @media (hover: hover) and (pointer: fine) {
    .fts__theme-btn:hover {
      background: var(--border);
      color: var(--text);
    }
  }

  /* ── Swatches ── */
  .fts__theme-swatch {
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 50%;
    flex-shrink: 0;
    border: 1.5px solid rgba(0, 0, 0, 0.1);
  }

  .fts__theme-swatch--minimal {
    background: linear-gradient(135deg, #f7f5f2 50%, #18181b 50%);
  }
  .fts__theme-swatch--modern {
    background: linear-gradient(135deg, #f0f0ff 50%, #6c47ff 50%);
  }
  .fts__theme-swatch--neobrutalist {
    background: linear-gradient(135deg, #f5f0e8 50%, #ff6b35 50%);
  }

  .fts__theme-name {
    flex: 1;
  }

  /* ── Entrance animation ── */
  .fts {
    animation: ftsAppear 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 1.2s both;
  }

  @keyframes ftsAppear {
    from {
      opacity: 0;
      transform: translateY(12px) scale(0.9);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>
