---
import type { PriceItem } from "@/types/config";
import { Icon } from "astro-icon/components";

export interface Props {
  item: PriceItem;
}

const { item } = Astro.props;
---

<div class="price-card">
  <div class="price-card__header">
    <span class="price-card__label">{item.label}</span>
    <div class="price-card__amount-wrapper">
      <span class="price-card__price">{item.price}</span>
      {item.period && <span class="price-card__period">/{item.period}</span>}
    </div>
  </div>

  {item.description && (
    <p class="price-card__desc">{item.description}</p>
  )}

  {item.features && item.features.length > 0 && (
    <ul class="price-card__features">
      {item.features.map((feature) => (
        <li class="price-card__feature">
          <Icon name="lucide:check" width="14" height="14" class="price-card__check" />
          <span>{feature}</span>
        </li>
      ))}
    </ul>
  )}

  {item.url && (
    <a href={item.url} class="price-card__btn">
      {item.buttonLabel || "Get Started"}
    </a>
  )}
</div>

<style>
  .price-card {
    background: var(--bg-card);
    border: var(--card-border-width) var(--card-border-style) var(--border);
    border-radius: var(--radius);
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    box-shadow: var(--shadow);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    transition: transform var(--transition), box-shadow var(--transition);
  }

  @media (min-width: 480px) {
    .price-card {
      padding: 2.25rem 1.75rem;
      gap: 1.75rem;
    }
  }

  .price-card:hover {
    transform: var(--card-transform-hover, translateY(-2px));
    box-shadow: var(--shadow-hover);
    border-color: var(--border-hover);
  }

  .price-card__header {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .price-card__label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  .price-card__amount-wrapper {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }

  .price-card__price {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--text);
    line-height: 1;
  }

  .price-card__period {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .price-card__desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .price-card__features {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .price-card__feature {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.875rem;
    color: var(--text);
  }

  .price-card__check {
    color: var(--accent);
    flex-shrink: 0;
  }

  .price-card__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 1.5rem;
    background: var(--accent);
    color: var(--accent-fg);
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: opacity var(--transition), transform var(--transition);
  }

  .price-card__btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
</style>
